<Modal IsVisible="isVisible" OnClose="onClose" Title="@title" HasCloseButton="false">
    <ChildContent>
        @text
    </ChildContent>
    <Footer>
        <div class="footer-btn">
            <div @onpointerup:stopPropagation @onpointerup="onClose" style="color:@(NoTextColor.Trim())">@NoText</div>
            <div @onpointerup:stopPropagation @onpointerup="onYes" style="color:@(YesTextColor.Trim())">@YesText</div>
        </div>
    </Footer>
</Modal>

@code {
    bool isVisible = false;
    // Func<bool, Task>? Callback;
    private TaskCompletionSource<bool>? tcs;
    string title = "";
    string text = "";

    [Parameter]
    public string YesText { get; set; } = "Yes";

    [Parameter]
    public string YesTextColor { get; set; } = "";

    [Parameter]
    public string NoText { get; set; } = "No";

    [Parameter]
    public string NoTextColor { get; set; } = "";


    public Task<bool> Open(string title, string text)
    {
        isVisible = true;
        this.title = title;
        this.text = text;

        InvokeAsync(StateHasChanged);
        tcs = new TaskCompletionSource<bool>();

        return tcs.Task;
    }

    void onClose()
    {
        isVisible = false;
        tcs?.TrySetResult(false);
    }

    void onYes()
    {
        isVisible = false;
        tcs?.TrySetResult(true);
    }
}