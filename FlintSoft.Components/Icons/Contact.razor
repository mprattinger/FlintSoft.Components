@inherits IconBase

<svg xmlns="http://www.w3.org/2000/svg"
     width="24"
     height="24"
     viewBox="0 0 24 24"
     fill="none"
     stroke="currentColor"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round"
     @onclick="() => OnClicked.InvokeAsync()"
     @onclick:stopPropagation="@StopPropagation"
     style="@StyleValue"
     class="@ClassValue">
    @if (Title is not null)
    {
        <title>@Title</title>
    }
     <path d="M16 2v2" /><path d="M17.915 22a6 6 0 0 0-12 0" /><path d="M8 2v2" /><circle cx="12" cy="12" r="4" /><rect x="3" y="4" width="18" height="18" rx="2" /></svg>

@code {
    protected override string ClassValue => $"lucide lucide-contact-round-icon lucide-contact-round {Class}".Trim();

    protected override string StyleValue => $"{Style}".Trim();
}
