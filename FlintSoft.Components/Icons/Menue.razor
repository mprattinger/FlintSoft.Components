@inherits IconBase

<svg xmlns="http://www.w3.org/2000/svg"
     id="@Id"
     width="24"
     height="24"
     viewBox="0 0 24 24"
     fill="none"
     stroke="currentColor"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round"
     style="@StyleValue"
     @onclick="() => OnClicked.InvokeAsync()"
     @onclick:stopPropagation="@StopPropagation"
     class="@ClassValue">
    @if (Title is not null)
    {
        <title>@Title</title>
    }
     <path d="M4 5h16" />
     <path d="M4 12h16" />
     <path d="M4 19h16" />
 </svg>

@code {
    protected override string ClassValue => $"lucide lucide-menu-icon lucide-menu {Class}".Trim();

    protected override string StyleValue => $"{Style}".Trim();
}